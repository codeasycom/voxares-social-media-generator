{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"
  },
  "include": ["remotion/**/*.ts", "remotion/**/*.tsx", "posts/**/*.tsx", "src/**/*.ts", "src/**/*.tsx"]
}
